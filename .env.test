# Dummy, non-secret values used only when running the automated test suite
# (npm test). Safe to commit — nothing here is a real credential, and
# consoleStream.ts/client.ts require these vars to be set just to import
# without throwing, even though tests never make real network calls.
DISCORD_TOKEN=test-token
CLIENT_ID=test-client-id
MC_MANAGER_API_URL=http://localhost:0
MC_MANAGER_USERNAME=test-user
MC_MANAGER_PASSWORD=test-password
