# Copy this file to .env (production) or .env.dev (local development with a
# separate dev bot application — see deploy/README.md and README notes on
# running a dev bot alongside the prod one) and fill in real values.

# Discord bot application (Developer Portal > your app > Bot / General Information)
DISCORD_TOKEN=
CLIENT_ID=

# Optional: set to a test server's ID for instant (guild-scoped) slash command
# registration instead of the ~1h global propagation delay. Leave unset in
# production so commands register globally.
GUILD_ID=

# mc-manager-server API this bot streams Minecraft chat from/to.
MC_MANAGER_API_URL=
MC_MANAGER_USERNAME=
MC_MANAGER_PASSWORD=
